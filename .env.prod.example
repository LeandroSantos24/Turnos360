# Variables del stack de PRODUCCIÓN / STAGING.
#
# Copiar como .env.prod EN EL SERVIDOR y completar. NO se versiona nunca
# (.gitignore ya excluye .env*). Este archivo es la plantilla.
#
# Generar cada secreto con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=turnos360
POSTGRES_PASSWORD=            # secreto propio, NO reusar el de desarrollo
POSTGRES_DB=turnos360

# ── Redis ───────────────────────────────────────────────
# Solo alfanumérico: viaja dentro de una URL (redis://:PASS@redis:6379/0)
# y los caracteres raros la rompen.
REDIS_PASSWORD=

# ── Secretos de la app ──────────────────────────────────
# DISTINTOS entre sí y distintos de los de desarrollo.
# SECRET_KEY  = firma de los JWT (rotarla desloguea a todos, nada más).
# FERNET_KEY  = encriptación de credenciales MP/WhatsApp/email.
#               Una vez en producción NO se rota a la ligera: cambiarla
#               deja ilegibles las credenciales ya guardadas.
SECRET_KEY=
FERNET_KEY=

# ── Super-admin (para el primer seed) ───────────────────
SUPERADMIN_EMAIL=leandro@turnos360.com.ar
SUPERADMIN_PASS=              # clave fuerte: controla el alta de TODAS las empresas

# ── URLs ────────────────────────────────────────────────
# STAGING UM (por IP de la instancia, sin dominio):
#   NEXT_PUBLIC_API_URL=http://10.20.30.40/api
#   PUBLIC_BASE_URL=http://10.20.30.40
#   API_BASE_URL=http://10.20.30.40/api
#   CORS_ORIGINS=http://10.20.30.40
#
# PRODUCCIÓN (con dominio y TLS):
#   NEXT_PUBLIC_API_URL=https://turnos360.com.ar/api
#   PUBLIC_BASE_URL=https://turnos360.com.ar
#   API_BASE_URL=https://turnos360.com.ar/api
#   CORS_ORIGINS=https://turnos360.com.ar,https://www.turnos360.com.ar
#
# OJO con NEXT_PUBLIC_API_URL: se hornea en el bundle del frontend EN BUILD
# TIME. Si la cambiás, hay que rebuildear el frontend, no alcanza reiniciar.
NEXT_PUBLIC_API_URL=
PUBLIC_BASE_URL=
API_BASE_URL=
CORS_ORIGINS=

# ── Email saliente ──────────────────────────────────────
# Contraseña de APLICACIÓN de Gmail, sin espacios.
# La actual viajó dentro de un zip: regenerala antes de producción.
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Ajustes del servidor ────────────────────────────────
# Workers de uvicorn. Con 2 GB de RAM dejá 2; con 4 GB podés ir a 4.
UVICORN_WORKERS=2

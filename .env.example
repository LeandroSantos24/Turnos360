# PostgreSQL (docker compose)
POSTGRES_USER=turnos360
POSTGRES_PASSWORD=turnos360
POSTGRES_DB=turnos360

# Backend
DATABASE_URL=postgresql+psycopg://turnos360:turnos360@localhost:5432/turnos360
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=cambiar-en-produccion
ENV=dev

# Entorno: "dev" o "prod". En prod, el backend exige un SECRET_KEY real.
ENV=dev

# Orígenes permitidos por CORS (separados por coma). En prod, los dominios reales:
#   CORS_ORIGINS=https://app.turnos360.com,https://turnos360.com
CORS_ORIGINS=http://localhost:3000
# ── PostgreSQL (docker compose) ─────────────────────────
POSTGRES_USER=turnos360
POSTGRES_PASSWORD=turnos360
POSTGRES_DB=turnos360

# ── Backend ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://turnos360:turnos360@localhost:5432/turnos360
REDIS_URL=redis://localhost:6379/0

# Entorno: "dev" o "prod". En prod el backend NO levanta sin
# SECRET_KEY y FERNET_KEY reales (fail-fast a propósito).
ENV=dev

# Firma de los JWT. Generá una real con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambiar-en-produccion

# Encriptación Fernet de credenciales por empresa (Mercado Pago / WhatsApp /
# email). SEPARADA de SECRET_KEY a propósito: rotar la firma de los JWT no
# debe romper lo que ya está encriptado en la base. En dev puede quedar vacía
# (deriva de SECRET_KEY, como siempre); en prod es OBLIGATORIA y distinta.
# Se genera igual que SECRET_KEY. Una vez en producción, NO se rota a la
# ligera: cambiarla deja ilegibles las credenciales guardadas.
FERNET_KEY=

# ── Super-admin (bootstrap: python -m app.seeds_minimo) ──
# En prod son OBLIGATORIAS antes de correr el seed.
# En dev, si faltan, queda admin@turnos360.com / superadmin360.
SUPERADMIN_EMAIL=admin@turnos360.com
SUPERADMIN_PASS=

# ── CORS: orígenes permitidos (separados por coma) ──────
# En prod: CORS_ORIGINS=https://turnos360.com.ar,https://www.turnos360.com.ar
CORS_ORIGINS=http://localhost:3000

# ── URLs base (local; en deploy van al dominio real) ────
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ── Email saliente (Gmail: contraseña de APLICACIÓN, sin espacios) ──
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
